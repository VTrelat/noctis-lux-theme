\RequirePackage[sfdefault]{FiraSans}
\RequirePackage{fontspec}
\setmonofont[Contextuals={Alternate}]{JetBrains Mono}

\makeatletter
\renewcommand*\verbatim@nolig@list{}
\makeatother

\setbeamertemplate{navigation symbols}{}

\RequirePackage{tikz}

% Frame title
\defbeamertemplate*{frametitle}{noctislux}[1][]{
  \vskip0.5cm%
  \begin{beamercolorbox}[wd=\paperwidth,ht=1.2cm]{frametitle}
    \begin{tikzpicture}
      \useasboundingbox(0,0) rectangle(\the\paperwidth,1.2);
      \fill[noctislux-orange] (0.2,0.1) rectangle(0.34,1.1);
      \ifx\insertframesubtitle\@empty%
        \node[anchor=west, text=noctislux-orange] at (0.45,0.6)
          {\usebeamerfont{frametitle}\insertframetitle};
      \else%
        \node[anchor=west, text=noctislux-orange] at (0.45,0.82)
          {\usebeamerfont{frametitle}\insertframetitle};
        \node[anchor=west, text=noctislux-orange] at (0.45,0.3)
          {\usebeamerfont{framesubtitle}\itshape\insertframesubtitle};
      \fi
    \end{tikzpicture}
  \end{beamercolorbox}
}