% beamerinnerthemenoctislux.sty
% Inner theme for the Noctis-Lux Beamer theme.
% tcolorbox environments match the PhD-manuscript style (environments.tex).
% All theorem-like environments accept an optional Beamer overlay spec <...>.

\RequirePackage{framed}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}   % enhanced skin, overlay unbroken and first, attach boxed title

% ---------------------------------------------------------------------------
% Itemize / TOC
% ---------------------------------------------------------------------------
\setbeamertemplate{itemize items}[circle]

\defbeamertemplate{section in toc}{circle numbered}{%
  \leavevmode\leftskip=.5ex%
  \llap{%
    \usebeamerfont*{section number projected}%
    \usebeamercolor{section number projected}%
    \begin{pgfpicture}{-1ex}{0ex}{1ex}{1ex}
      \color{noctislux-pink}
      \pgfpathcircle{\pgfpoint{0pt}{.6ex}}{1.25ex}
      \pgfusepath{fill}
      \pgftext[base]{\color{fg}\inserttocsectionnumber}
    \end{pgfpicture}\kern.5ex%
  }%
  \kern.5ex\inserttocsection\par}
\setbeamertemplate{section in toc}[circle numbered]
\setbeamercolor{section in toc}{fg=noctislux-pink}
\setbeamerfont{section in toc}{size=\normalsize, series=\bfseries}

\defbeamertemplate{subsection in toc}{circle unnumbered}{%
  \vspace{0.5ex} % Add vertical padding
  \leavevmode\leftskip=3ex%
  \llap{%
    \begin{pgfpicture}{-1ex}{0ex}{1ex}{1ex}
      \color{noctislux-blue}
      \pgfpathcircle{\pgfpoint{0pt}{.6ex}}{.4ex}
      \pgfusepath{fill}
    \end{pgfpicture}\kern.5ex%
  }%
  \kern.5ex\inserttocsubsection\par}
\setbeamertemplate{subsection in toc}[circle unnumbered]
\setbeamercolor{subsection in toc}{fg=noctislux-blue}
\setbeamerfont{subsection in toc}{size=\small}

% ---------------------------------------------------------------------------
% Block / code  (original framed environments, kept unchanged)
% ---------------------------------------------------------------------------
\setbeamercolor{block title}{fg=noctislux-orange}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamercolor{block body}{fg=noctislux-blue}

\setbeamercolor{block title example}{fg=noctislux-green}
\setbeamerfont{block body example}{shape=\itshape}

% title page
\setbeamercolor{title}{fg=noctislux-blue}
\setbeamerfont{title}{size=\huge, series=\bfseries}
\setbeamercolor{author}{fg=noctislux-orange}
\setbeamerfont{author}{size=\large, series=\bfseries}
\setbeamercolor{institute}{fg=noctislux-orange}
\setbeamerfont{institute}{size=\normalsize, shape=\itshape}
\setbeamercolor{date}{fg=noctislux-blue}
\setbeamerfont{date}{}

% footline
\setbeamercolor{footline}{fg=noctislux-blue}
\setbeamerfont{footline}{size=\tiny}
\setbeamertemplate{footline}{%
  % progress bar
  \begin{beamercolorbox}[wd=\paperwidth,ht=2pt,dp=0pt]{footline}%
    \textcolor{noctislux-blue}{%
      \rule[0pt]{\dimexpr\paperwidth*\insertframenumber/\inserttotalframenumber\relax}{2pt}%
    }%
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=\paperwidth,ht=2.25ex,dp=1ex]{footline}
    \hspace*{1em}
    \insertshortauthor
    \hfill
    \insertshorttitle
    \hfill
    \insertframenumber/\inserttotalframenumber
    \hspace*{1em}
  \end{beamercolorbox}
}

% args: title, color, width (opt), overlay specification
\renewenvironment<>{block}[3][.9\textwidth]{%
  \setlength{\textwidth}{#1}
  \begin{actionenv}#4%
    \def\insertblocktitle{\color{#3}#2}%
    \par%
    \usebeamertemplate{block begin}%
    \def\FrameCommand
    {
      {\color{#3}\vrule width 2.5 pt}
      \hspace{0pt}
    }
    \vspace*{-2ex}\MakeFramed{\hsize\hsize\advance\hsize-\width\FrameRestore}}
    {\endMakeFramed%
    \par%
    \usebeamertemplate{block end}%
  \end{actionenv}}

\newenvironment<>{code}[1][.9\textwidth]{%
\setlength{\textwidth}{#1}
\begin{actionenv}#2%
  \def\insertblocktitle{}%
  \par%
  \usebeamertemplate{block begin}%
  \def\FrameCommand{%
    \noindent\hspace*{0.14em}%
    {\color{noctislux-pink}\vrule width 2.5pt}%
    \hspace{.5em}%
  }%
  \vspace*{-4ex}\MakeFramed{\hsize\hsize\advance\hsize-\width\FrameRestore}%
  % overlay the Lean logo once, after the frame starts so measurement doesn't eat it
  \noindent\smash{\hspace*{-1.4em}{\raisebox{-1.5em}{\rotatebox{90}{\scalebox{.4}{\lean}}}}}%
}%
{\endMakeFramed%
\par%
\usebeamertemplate{block end}%
\end{actionenv}}

% ---------------------------------------------------------------------------
% Shared counter for tcolorbox theorem-like environments.
% A single presentation-wide counter increments across all theorem types,
% just like the PhD manuscript (thmcounter).
% The counter is stepped BEFORE actionenv so the number is consistent
% regardless of which overlay slides are active.
% ---------------------------------------------------------------------------
\newcounter{nlxthmcounter}
\renewcommand{\thenlxthmcounter}{\arabic{nlxthmcounter}}
\resetcounteronoverlays{nlxthmcounter}

% Helper: decorative 6 mm top-left accent bar (drawn inside tcolorbox overlay).
\newcommand{\tcbenvtopbar}[1]{%
  \draw[line width=2pt, color=#1, line cap=butt]
    (frame.north west) -- ([xshift=6mm]frame.north west);%
}

% ---------------------------------------------------------------------------
% Base tcb styles.
% nlxenvbase  : beige bg, no visible frame border, rounded east / sharp west.
% nlxenvaccent: tinted bg + left bar + floating title tab (solid bg, white text).
% No 'breakable' — Beamer frames never paginate.
% ---------------------------------------------------------------------------
\tcbset{
  nlxenvbase/.style={
    enhanced,
    arc=5pt,
    sharp corners=west,
    boxrule=0pt,
    frame hidden,
    colback=beige!30,
    left=8pt, right=8pt, top=4pt, bottom=4pt,
    before upper={\setlength{\parskip}{4pt}},
  },
  nlxenvaccent/.style n args={1}{
    colback=#1!15,
    top=10pt,
    borderline west={2pt}{0pt}{#1},
    fonttitle=\small\sffamily\bfseries\color{white},
    attach boxed title to top left={
      yshift={-\dimexpr\tcboxedtitleheight/2\relax},
      xshift=6mm,
    },
    boxed title style={
      enhanced,
      colback=#1,
      colframe=#1,
      arc=2pt,
      boxrule=0pt,
      left=4pt, right=4pt, top=1pt, bottom=1pt,
    },
  },
}

% ---------------------------------------------------------------------------
% THEOREM  (pink, boxed title tab)
% \begin{theorem}<overlay>  ...  \end{theorem}
% ---------------------------------------------------------------------------
\@ifundefined{theorem}{}{\let\theorem\relax\let\endtheorem\relax}
\newenvironment<>{theorem}{%
  \stepcounter{nlxthmcounter}%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase, nlxenvaccent={noctislux-pink},
    title={Theorem~\thenlxthmcounter},
    overlay unbroken and first={\tcbenvtopbar{noctislux-pink}},
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% LEMMA  (pink, boxed title tab)
% ---------------------------------------------------------------------------
\@ifundefined{lemma}{}{\let\lemma\relax\let\endlemma\relax}
\newenvironment<>{lemma}{%
  \stepcounter{nlxthmcounter}%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase, nlxenvaccent={noctislux-pink},
    title={Lemma~\thenlxthmcounter},
    overlay unbroken and first={\tcbenvtopbar{noctislux-pink}},
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% COROLLARY  (pink, boxed title tab)
% ---------------------------------------------------------------------------
\@ifundefined{corollary}{}{\let\corollary\relax\let\endcorollary\relax}
\newenvironment<>{corollary}{%
  \stepcounter{nlxthmcounter}%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase, nlxenvaccent={noctislux-pink},
    title={Corollary~\thenlxthmcounter},
    overlay unbroken and first={\tcbenvtopbar{noctislux-pink}},
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% DEFINITION  (orange, boxed title tab)
% ---------------------------------------------------------------------------
\@ifundefined{definition}{}{\let\definition\relax\let\enddefinition\relax}
\newenvironment<>{definition}{%
  \stepcounter{nlxthmcounter}%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase, nlxenvaccent={noctislux-orange},
    title={Definition~\thenlxthmcounter},
    overlay unbroken and first={\tcbenvtopbar{noctislux-orange}},
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% EXAMPLE  (green, inline bold label)
% ---------------------------------------------------------------------------
\@ifundefined{example}{}{\let\example\relax\let\endexample\relax}
\newenvironment<>{example}{%
  \stepcounter{nlxthmcounter}%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase,
    colback=noctislux-green!5,
    borderline west={2pt}{0pt}{noctislux-green},
    before upper={%
      \setlength{\parskip}{4pt}%
      \textcolor{noctislux-green}{\textbf{Example~\thenlxthmcounter.}}\enspace%
    },
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% REMARK  (blue, inline bold label)
% ---------------------------------------------------------------------------
\@ifundefined{remark}{}{\let\remark\relax\let\endremark\relax}
\newenvironment<>{remark}{%
  \stepcounter{nlxthmcounter}%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase,
    colback=noctislux-blue!5,
    borderline west={2pt}{0pt}{noctislux-blue!70},
    fontupper={\color{noctislux-dark-blue}},
    before upper={%
      \setlength{\parskip}{4pt}%
      \textcolor{noctislux-blue!70}{\textbf{Remark~\thenlxthmcounter.}}\enspace%
    },
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% FACT  (blue, inline bold label, no counter)
% ---------------------------------------------------------------------------
\@ifundefined{fact}{}{\let\fact\relax\let\endfact\relax}
\newenvironment<>{fact}{%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase,
    colback=noctislux-blue!7,
    borderline west={2pt}{0pt}{noctislux-blue!70},
    before upper={%
      \setlength{\parskip}{4pt}%
      \textcolor{noctislux-blue!70}{\textbf{Fact.}}\enspace%
    },
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% NOTE  (beige/brown, inline bold label, no counter)
% NB: Beamer's \note{} command is unrelated — \begin{note} is safe to define.
% ---------------------------------------------------------------------------
\newenvironment<>{note}{%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase,
    colback=beige!50,
    borderline west={2pt}{0pt}{beige!70!black},
    fontupper={\color{beige!40!black}},
    before upper={%
      \setlength{\parskip}{4pt}%
      \textcolor{beige!70!black}{\textbf{Note.}}\enspace%
    },
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}

% ---------------------------------------------------------------------------
% PROOF  (blue tint, italic label, QED flush-right)
% Beamer defines proof via \newenvironment<>, which internally creates a
% \beamerx@proof token.  Using \renewenvironment<> here updates it cleanly
% without triggering the "already defined" error.
% ---------------------------------------------------------------------------
\renewenvironment<>{proof}{%
  \begin{actionenv}#1%
  \begin{tcolorbox}[
    nlxenvbase,
    colback=noctislux-blue!2,
    borderline west={2pt}{0pt}{noctislux-blue!70},
    before upper={\setlength{\parskip}{4pt}\textit{Proof.}\enspace},
    after upper={\unskip\nobreak\hspace*{1em}\hfill\ensuremath{\square}},
  ]%
}{%
  \end{tcolorbox}%
  \end{actionenv}%
}
